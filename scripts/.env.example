# Path to Obsidian vault with family data (relative to scripts/ or absolute)
VAULT_PATH=../sample-family

# Home person — the root of the family tree
ROOT_PERSON=Brian Johnson

# Path to GEDCOM file (optional — leave empty to skip GEDCOM import)
GEDCOM_PATH=

# Directories to exclude when scanning the vault
EXCLUDE_DIRS=Archive,Templates,.obsidian,Photos
